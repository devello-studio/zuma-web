# Copy to ".env" or ".env.local" and fill in values (never commit real secrets).

# --- Vite (browser) — only vars prefixed with VITE_ are exposed to the client ---
# Required for `npm run dev` / production build. For Docker, this must be set in .env
# so docker-compose can pass it as a build-arg (the image does not copy .env).
VITE_TURNSTILE_SITE_KEY=

# --- api/contact.js (server) — required when the handler runs (see below) ---
TURNSTILE_SECRET_KEY=
RESEND_API_KEY=
# Use quotes if the value has spaces or angle brackets (recommended for docker compose).
RESEND_FROM="Name <hello@example.com>"
FORM_NOTIFICATION_EMAIL=
